<Window x:Class="BackupManager.AddEditProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Профиль" Height="200" Width="400">
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Text="Имя:" Grid.Row="0"/>
		<TextBox x:Name="NameTextBox" Grid.Row="0" Margin="50,0,0,0"/>

		<TextBlock Text="Оригинальная папка:" Grid.Row="1" Margin="0,10,0,0"/>
		<TextBox x:Name="OriginalPathTextBox" Grid.Row="1" Margin="120,10,50,0"/>
		<Button Content="..." Click="BrowseOriginal_Click" Grid.Row="1" HorizontalAlignment="Right" Margin="0,10,0,0" Width="30"/>

		<TextBlock Text="Папка бэкапов:" Grid.Row="2" Margin="0,10,0,0"/>
		<TextBox x:Name="BackupPathTextBox" Grid.Row="2" Margin="120,10,50,0"/>
		<Button Content="..." Click="BrowseBackup_Click" Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0" Width="30"/>

		<StackPanel Orientation="Horizontal" Grid.Row="3" HorizontalAlignment="Right" Margin="0,20,0,0">
			<Button Content="OK" Click="OK_Click" Margin="5"/>
			<Button Content="Отмена" Click="Cancel_Click" Margin="5"/>
		</StackPanel>
	</Grid>
</Window>